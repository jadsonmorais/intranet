# Environment Variables Template
# Copy this file to .env and fill in the values

# Flask
SECRET_KEY=your-secret-key-here          # obrigatório — gere com: python -c "import secrets; print(secrets.token_hex(32))"
DATABASE_URL=postgresql://user:password@host:5432/dbname  # SQLite apenas para dev local
FLASK_DEBUG=0                             # 1 apenas em desenvolvimento local

# Superadmin (email que sempre terá acesso admin e não pode ser removido)
SUPERADMIN_EMAIL=suporte@carmelhoteis.com.br

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# Zoho
ZOHO_ACCOUNTS_URL=https://accounts.zoho.com
ZOHO_CLIENT_ID=your-zoho-client-id-here
ZOHO_CLIENT_SECRET=your-zoho-client-secret-here

# Google Sheets
GOOGLE_SHEETS_CREDENTIALS_PATH=
GOOGLE_SHEETS_ID=
GOOGLE_SHEETS_TAB=

# Server
SERVER_NAME=localhost:5000
