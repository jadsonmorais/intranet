# ─── App ──────────────────────────────────────────────────────────
SECRET_KEY=troque-por-uma-chave-aleatoria-longa
FLASK_DEBUG=0
PORT=5000

# ─── Banco (carmel-postgres da infra compartilhada) ───────────────
DATABASE_URL=postgresql://carmel:changeme@carmel-postgres:5432/carmel
CARMEL_DB_URL=postgresql://carmel:changeme@carmel-postgres:5432/carmel

# ─── Google OAuth ─────────────────────────────────────────────────
# Console: https://console.cloud.google.com → APIs & Services → Credentials
# Redirect URI autorizada: http://localhost:5000/auth/authorize
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Zoho OAuth (opcional) ────────────────────────────────────────
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_ACCOUNTS_URL=https://accounts.zoho.com

# ─── Google Sheets (opcional) ────────────────────────────────────
GOOGLE_SHEETS_CREDENTIALS_PATH=instance/google-service-account.json
GOOGLE_SHEETS_ID=
GOOGLE_SHEETS_TAB=dashboard_import_template

# ─── Acesso ───────────────────────────────────────────────────────
SUPERADMIN_EMAIL=suporte@carmelhoteis.com.br
